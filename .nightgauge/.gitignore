# Nightgauge Pipeline — Generated Artifacts
# This file is managed by the Nightgauge extension and should be committed.
# It prevents pipeline-generated files from polluting git status.
#
# Files that ARE tracked (committed):
#   config.yaml           — repository-wide pipeline configuration
#   .gitignore            — this file
#   */.gitkeep            — preserve directory structure
# nightgauge-gitignore-version: 5

# ─── Pipeline context, state, and execution data ─────────────────────
pipeline/*
!pipeline/.gitkeep
!pipeline/history/
pipeline/history/*
!pipeline/history/.gitkeep

# ─── Feature plans (generated by feature-planning stage) ─────────────
plans/*
!plans/.gitkeep

# ─── Session and execution logs ──────────────────────────────────────
logs/*
!logs/.gitkeep

# ─── Analysis, experiments, and brownfield reports ───────────────────
# Anchored with / so it only matches .nightgauge/analysis/, not pipeline/analysis/
/analysis/

# ─── Brownfield assessment history ──────────────────────────────────
# Anchored with / so it only matches .nightgauge/history/, not pipeline/history/
/history/

# ─── Root-level transient files ─────────────────────────────────────
/state.json
/.refresh-trigger
/config.local.yaml
/config.yaml.tmp
/complexity-model.yaml
/outcome-recovery.jsonl
/cross-project-patterns.json
/saved-queries.yaml
# Field IDs are stored in config.yaml (project.fields section)
# Legacy project-field-mappings.json is no longer used
/project-field-mappings.json

# ─── Autonomous scheduler state ─────────────────────────────────────
/autonomous/

# ─── Skill usage telemetry (local, per-machine) ─────────────────────
/skills/

# ─── Skill evaluation runs (transient; baseline.jsonl is the tracked
# reference — see docs/SKILL_EVALUATION.md) ──────────────────────────
/skill-evals/*
!/skill-evals/baseline.jsonl

# ─── Model evaluation runs (transient by default — the eval SDK writes
# here, and mock runs carry no evidential weight). A live run cited by a
# spike or ADR is promoted to evidence/ and tracked: live agentic runs are
# nondeterministic, so they cannot be re-derived, only re-purchased.
# See docs/MODEL_EVALUATION.md. ──────────────────────────────────────
/model-evals/*
!/model-evals/evidence/

# ─── Pipeline queue state ───────────────────────────────────────────
pipeline/queue-state.json

# ─── Documentation watch snapshots (fetched page hashes) ──────────────
/doc-snapshots/

# ─── Health telemetry (gate metrics, trend data) ─────────────────────
/health/

# ─── Knowledge base (scaffolded per-issue, local pipeline data) ──────
/knowledge/

# ─── Auto-retro failure reports (local diagnostics) ─────────────────
/retros/

# ─── Generated reports (backlog triage, health, security, etc.) ─────
/backlog-*.md
/health-report.json
/security-audit.json
/modernization-plan.json
/dep-modernize-report.json

# ─── Release watch state and reports ────────────────────────
# Tracked: last-seen.json (state file — shared across team)
# Ignored: reports/ (transient analysis files)
/release-watch/reports/
!/release-watch/
!/release-watch/last-seen.json
