        <label for="autonomous.refinement_enabled" class="toggle-switch"></label>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="autonomous.refinement_interval" class="setting-label">Refinement Interval </label>
        <p class="setting-description">Time between refinement scan cycles (e.g. &quot;60s&quot;, &quot;5m&quot;). Minimum: 30s.</p>
        
      </div>
      <div class="setting-control">
        <input type="text"
               id="autonomous.refinement_interval"
               class="text-input"
               data-path="autonomous.refinement_interval"
               value="60s"
               placeholder="60s"
               >
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="autonomous.refinement_max_concurrent" class="setting-label">Max Concurrent Refinements </label>
        <p class="setting-description">Maximum number of issues refined at the same time (1–3).</p>
        
      </div>
      <div class="setting-control">
        <input type="number"
               id="autonomous.refinement_max_concurrent"
               class="number-input"
               data-path="autonomous.refinement_max_concurrent"
               value="1"
               min="1"
               max="3"
               
               >
      </div>
    </div>
  
      </div>
      <div class="subsection">
        <h4 class="subsection-title">Auto-Actionable</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="autonomous.auto_actionable" class="setting-label">Auto-Actionable </label>
        <p class="setting-description">⚠️ When enabled, AI-refined issues are automatically set to Ready for pipeline processing. When disabled, refined issues go to Backlog for manual review.</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="autonomous.auto_actionable"
               class="toggle-input"
               data-path="autonomous.auto_actionable"
               
               >
        <label for="autonomous.auto_actionable" class="toggle-switch"></label>
      </div>
    </div>
  
