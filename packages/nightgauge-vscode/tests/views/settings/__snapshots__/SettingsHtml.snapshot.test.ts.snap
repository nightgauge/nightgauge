      <div class="section " id="section-platform">
        
    <div class="section-header" data-section="platform">
      <div class="section-title-row">
        <span class="section-chevron codicon codicon-chevron-down"></span>
        <span class="codicon codicon-key section-icon"></span>
        <h3 class="section-title">Platform</h3>
        
        <a href="#" class="doc-link" data-doc="docs/CONFIGURATION.md#platform-configuration" title="View documentation">
         <span class="codicon codicon-link-external"></span>
       </a>
      </div>
      <p class="section-description">License key, API connection, and platform feature settings</p>
    </div>
  
        
    <div class="section-content">
      <div class="subsection">
        <h4 class="subsection-title">License</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="platform.license_key" class="setting-label">License Key </label>
        <p class="setting-description">Your Nightgauge license key (format: ib_live_xxx). Enables paid tier features. Leave blank to run in community tier.</p>
        
      </div>
      <div class="setting-control">
        <div class="secret-input-wrapper">
          <input type="password"
                 id="platform.license_key"
                 class="text-input"
                 data-path="platform.license_key"
                 value=""
                 placeholder="ib_live_..."
                 autocomplete="off"
                 disabled>
          
        </div>
      </div>
    </div>
  
      </div>
      <div class="subsection">
        <h4 class="subsection-title">Connection</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="platform.enabled" class="setting-label">Platform Features </label>
        <p class="setting-description">Enable platform API communication. Set to off for fully offline mode.</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="platform.enabled"
               class="toggle-input"
               data-path="platform.enabled"
               
               disabled>
        <label for="platform.enabled" class="toggle-switch"></label>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="platform.api_url" class="setting-label">API URL </label>
        <p class="setting-description">Platform API endpoint. Change only for dev or self-hosted environments.</p>
        
      </div>
      <div class="setting-control">
        <input type="text"
               id="platform.api_url"
               class="text-input"
               data-path="platform.api_url"
               value="https://api.nightgauge.dev"
               placeholder="https://api.nightgauge.dev"
               disabled>
      </div>
    </div>
  
      </div>
      <div class="subsection">
        <h4 class="subsection-title">Advanced</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="platform.tier_override" class="setting-label">Tier Override </label>
        <p class="setting-description">Force a specific tier, bypassing license validation. Leave blank to use automatic tier from your license key.</p>
        
      </div>
      <div class="setting-control">
        <select id="platform.tier_override"
                class="select-input"
                data-path="platform.tier_override"
                disabled>
          <option value="" selected>Auto (use license key)</option><option value="community" >Community</option><option value="pro" >Pro</option><option value="team" >Team</option><option value="enterprise" >Enterprise</option>
        </select>
      </div>
    </div>
  
      </div>
    </div>
  
      </div>
    
      <div class="section " id="section-project">
        
    <div class="section-header" data-section="project">
      <div class="section-title-row">
        <span class="section-chevron codicon codicon-chevron-down"></span>
        <span class="codicon codicon-project section-icon"></span>
        <h3 class="section-title">Project Board</h3>
        
        <a href="#" class="doc-link" data-doc="docs/CONFIGURATION.md#project" title="View documentation">
         <span class="codicon codicon-link-external"></span>
       </a>
      </div>
      <p class="section-description">GitHub Project board integration settings</p>
    </div>
  
        
    <div class="section-content">
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="project.number" class="setting-label">Project Number </label>
        <p class="setting-description">GitHub Project board number (required for issue tracking)</p>
        
      </div>
      <div class="setting-control">
        <input type="number"
               id="project.number"
               class="number-input"
               data-path="project.number"
               value=""
               min="1"
               
               
               disabled>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="project.auto_dates" class="setting-label">Auto-set Dates </label>
        <p class="setting-description">Automatically update start/end dates on status changes</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="project.auto_dates"
               class="toggle-input"
               data-path="project.auto_dates"
               checked
               disabled>
        <label for="project.auto_dates" class="toggle-switch"></label>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="project.sprint.current" class="setting-label">Current Sprint </label>
        <p class="setting-description">Current sprint name or identifier</p>
        
      </div>
      <div class="setting-control">
        <input type="text"
               id="project.sprint.current"
               class="text-input"
               data-path="project.sprint.current"
               value=""
               placeholder="Sprint 1"
               disabled>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="project.sprint.duration_weeks" class="setting-label">Sprint Duration </label>
        <p class="setting-description">Sprint duration in weeks</p>
        
      </div>
      <div class="setting-control">
        <input type="number"
               id="project.sprint.duration_weeks"
               class="number-input"
               data-path="project.sprint.duration_weeks"
               value=""
               min="1"
               max="8"
               
               disabled>
      </div>
    </div>
  
    </div>
  
      </div>
    
      <div class="section " id="section-pull_request">
        
    <div class="section-header" data-section="pull_request">
      <div class="section-title-row">
        <span class="section-chevron codicon codicon-chevron-down"></span>
        <span class="codicon codicon-git-pull-request section-icon"></span>
        <h3 class="section-title">Pull Request</h3>
        
        <a href="#" class="doc-link" data-doc="docs/CONFIGURATION.md#pr" title="View documentation">
         <span class="codicon codicon-link-external"></span>
       </a>
      </div>
      <p class="section-description">PR creation and merge defaults</p>
    </div>
  
        
    <div class="section-content">
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pull_request.merge_strategy" class="setting-label">Merge Strategy </label>
        <p class="setting-description">How PRs are merged into the base branch</p>
        
      </div>
      <div class="setting-control">
        <select id="pull_request.merge_strategy"
                class="select-input"
                data-path="pull_request.merge_strategy"
                disabled>
          <option value="squash" selected>Squash and merge</option><option value="merge" >Create a merge commit</option><option value="rebase" >Rebase and merge</option>
        </select>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pull_request.delete_branch" class="setting-label">Delete Branch </label>
        <p class="setting-description">Delete source branch after merge</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pull_request.delete_branch"
               class="toggle-input"
               data-path="pull_request.delete_branch"
               checked
               disabled>
        <label for="pull_request.delete_branch" class="toggle-switch"></label>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pull_request.auto_merge" class="setting-label">Auto Merge </label>
        <p class="setting-description">Automatically merge when checks pass</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pull_request.auto_merge"
               class="toggle-input"
               data-path="pull_request.auto_merge"
               checked
               disabled>
        <label for="pull_request.auto_merge" class="toggle-switch"></label>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pull_request.auto_merge_epic" class="setting-label">Auto Merge Epic PR </label>
        <p class="setting-description">Auto-merge epic→main PR when all sub-issues complete</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pull_request.auto_merge_epic"
               class="toggle-input"
               data-path="pull_request.auto_merge_epic"
               checked
               disabled>
        <label for="pull_request.auto_merge_epic" class="toggle-switch"></label>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pull_request.epic_merge_strategy" class="setting-label">Epic Merge Strategy </label>
        <p class="setting-description">How epic branches are merged into main (merge preserves sub-issue commits)</p>
        
      </div>
      <div class="setting-control">
        <select id="pull_request.epic_merge_strategy"
                class="select-input"
                data-path="pull_request.epic_merge_strategy"
                disabled>
          <option value="merge" selected>Create a merge commit (recommended)</option><option value="squash" >Squash and merge</option><option value="rebase" >Rebase and merge</option>
        </select>
      </div>
    </div>
  
      
    <div class="setting-row setting-row-list ">
      <div class="setting-info">
        <label for="pull_request.reviewers" class="setting-label">Default Reviewers </label>
        <p class="setting-description">GitHub usernames to request reviews from</p>
        
      </div>
      <div class="setting-control list-control">
        <div class="list-items" id="pull_request.reviewers-items">
          <div class="list-empty">No items</div>
        </div>
        <div class="list-add">
          <input type="text"
                 id="pull_request.reviewers-input"
                 class="list-input"
                 placeholder="username"
                 disabled>
          <button class="list-add-btn" data-path="pull_request.reviewers" disabled>
            <span class="codicon codicon-add"></span>
          </button>
        </div>
      </div>
    </div>
  
    </div>
  
      </div>
    
      <div class="section " id="section-branch">
        
    <div class="section-header" data-section="branch">
      <div class="section-title-row">
        <span class="section-chevron codicon codicon-chevron-down"></span>
        <span class="codicon codicon-git-branch section-icon"></span>
        <h3 class="section-title">Branch</h3>
        
        <a href="#" class="doc-link" data-doc="docs/CONFIGURATION.md#branch" title="View documentation">
         <span class="codicon codicon-link-external"></span>
       </a>
      </div>
      <p class="section-description">Branch naming and protection rules</p>
    </div>
  
        
    <div class="section-content">
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="branch.base" class="setting-label">Base Branch </label>
        <p class="setting-description">Default target branch for pull requests</p>
        
      </div>
      <div class="setting-control">
        <input type="text"
               id="branch.base"
               class="text-input"
               data-path="branch.base"
               value="main"
               placeholder="main"
               disabled>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="branch.suggestions" class="setting-label">Branch Suggestions </label>
        <p class="setting-description">Suggest branch names based on issue</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="branch.suggestions"
               class="toggle-input"
               data-path="branch.suggestions"
               checked
               disabled>
        <label for="branch.suggestions" class="toggle-switch"></label>
      </div>
    </div>
  
      
    <div class="setting-row setting-row-list ">
      <div class="setting-info">
        <label for="branch.protected" class="setting-label">Protected Branches </label>
        <p class="setting-description">Branches that should not receive direct pushes</p>
        
      </div>
      <div class="setting-control list-control">
        <div class="list-items" id="branch.protected-items">
          
        <div class="list-item" data-index="0">
          <span class="list-item-text">main</span>
          <button class="list-item-remove" data-path="branch.protected" data-index="0" disabled>
            <span class="codicon codicon-close"></span>
          </button>
        </div>
      
        <div class="list-item" data-index="1">
          <span class="list-item-text">master</span>
          <button class="list-item-remove" data-path="branch.protected" data-index="1" disabled>
            <span class="codicon codicon-close"></span>
          </button>
        </div>
      
        </div>
        <div class="list-add">
          <input type="text"
                 id="branch.protected-input"
                 class="list-input"
                 placeholder="branch-name"
                 disabled>
          <button class="list-add-btn" data-path="branch.protected" disabled>
            <span class="codicon codicon-add"></span>
          </button>
        </div>
      </div>
    </div>
  
    </div>
  
      </div>
    
      <div class="section " id="section-issue">
        
    <div class="section-header" data-section="issue">
      <div class="section-title-row">
        <span class="section-chevron codicon codicon-chevron-down"></span>
        <span class="codicon codicon-issues section-icon"></span>
        <h3 class="section-title">Issue</h3>
        
        <a href="#" class="doc-link" data-doc="docs/CONFIGURATION.md#issue" title="View documentation">
         <span class="codicon codicon-link-external"></span>
       </a>
      </div>
      <p class="section-description">Issue pickup and assignment settings</p>
    </div>
  
        
    <div class="section-content">
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="issue.default_status" class="setting-label">Default Project Status </label>
        <p class="setting-description">Initial project status for newly created issues</p>
        
      </div>
      <div class="setting-control">
        <select id="issue.default_status"
                class="select-input"
                data-path="issue.default_status"
                disabled>
          <option value="backlog" selected>Backlog</option><option value="ready" >Ready</option>
        </select>
      </div>
    </div>
  
    </div>
  
      </div>
    
      <div class="section section-locked" id="section-pipeline">
        
    <div class="section-header" data-section="pipeline">
      <div class="section-title-row">
        <span class="section-chevron codicon codicon-chevron-down"></span>
        <span class="codicon codicon-play section-icon"></span>
        <h3 class="section-title">Pipeline</h3>
        <span class="section-lock-icon codicon codicon-lock" title="Locked while pipeline is running"></span>
        <a href="#" class="doc-link" data-doc="docs/CONFIGURATION.md#pipeline" title="View documentation">
         <span class="codicon codicon-link-external"></span>
       </a>
      </div>
      <p class="section-description">Pipeline execution and automation settings</p>
    </div>
  
        
    <div class="section-content">
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pipeline.max_concurrent" class="setting-label">Max Concurrent Slots </label>
        <p class="setting-description">Maximum number of pipeline issues running at the same time. Applies to both manually-picked-up issues and the autonomous scheduler. Changes take effect live — no restart required.</p>
        
      </div>
      <div class="setting-control">
        <select id="pipeline.max_concurrent"
                class="select-input"
                data-path="pipeline.max_concurrent"
                disabled>
          <option value="1" selected>1 (sequential)</option><option value="2" >2</option><option value="3" >3</option><option value="4" >4</option><option value="5" >5</option>
        </select>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pipeline.ci_timeout" class="setting-label">CI Timeout </label>
        <p class="setting-description">Maximum time to wait for CI checks (minutes)</p>
        
      </div>
      <div class="setting-control">
        <input type="number"
               id="pipeline.ci_timeout"
               class="number-input"
               data-path="pipeline.ci_timeout"
               value="10"
               min="1"
               max="60"
               
               disabled>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pipeline.auto_fix" class="setting-label">Auto Fix </label>
        <p class="setting-description">Automatically fix linting issues during development</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pipeline.auto_fix"
               class="toggle-input"
               data-path="pipeline.auto_fix"
               checked
               disabled>
        <label for="pipeline.auto_fix" class="toggle-switch"></label>
      </div>
    </div>
  
      
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pipeline.architecture_approval.enabled" class="setting-label">Architecture Approval Gate </label>
        <p class="setting-description">Pause before feature-dev when a plan is high-impact (production-touching area, major dependency bumps) until a human approves via the approved:architecture label or the approval prompt. Disable for fully-autonomous operation.</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pipeline.architecture_approval.enabled"
               class="toggle-input"
               data-path="pipeline.architecture_approval.enabled"
               checked
               disabled>
        <label for="pipeline.architecture_approval.enabled" class="toggle-switch"></label>
      </div>
    </div>
  
      <div class="subsection">
        <h4 class="subsection-title">Skip Checks</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pipeline.skip_checks.tests" class="setting-label">Skip Tests </label>
        <p class="setting-description">Skip running tests during pipeline</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pipeline.skip_checks.tests"
               class="toggle-input"
               data-path="pipeline.skip_checks.tests"
               
               disabled>
        <label for="pipeline.skip_checks.tests" class="toggle-switch"></label>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pipeline.skip_checks.lint" class="setting-label">Skip Lint </label>
        <p class="setting-description">Skip linting during pipeline</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pipeline.skip_checks.lint"
               class="toggle-input"
               data-path="pipeline.skip_checks.lint"
               
               disabled>
        <label for="pipeline.skip_checks.lint" class="toggle-switch"></label>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pipeline.skip_checks.typecheck" class="setting-label">Skip Type Check </label>
        <p class="setting-description">Skip type checking during pipeline</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pipeline.skip_checks.typecheck"
               class="toggle-input"
               data-path="pipeline.skip_checks.typecheck"
               
               disabled>
        <label for="pipeline.skip_checks.typecheck" class="toggle-switch"></label>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="pipeline.skip_checks.build" class="setting-label">Skip Build </label>
        <p class="setting-description">Skip build verification during pipeline</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="pipeline.skip_checks.build"
               class="toggle-input"
               data-path="pipeline.skip_checks.build"
               
               disabled>
        <label for="pipeline.skip_checks.build" class="toggle-switch"></label>
      </div>
    </div>
  
      </div>
    </div>
  
      </div>
    
      <div class="section section-locked" id="section-routing">
        
    <div class="section-header" data-section="routing">
      <div class="section-title-row">
        <span class="section-chevron codicon codicon-chevron-down"></span>
        <span class="codicon codicon-git-compare section-icon"></span>
        <h3 class="section-title">Routing</h3>
        <span class="section-lock-icon codicon codicon-lock" title="Locked while pipeline is running"></span>
        <a href="#" class="doc-link" data-doc="docs/CONFIGURATION.md#routing" title="View documentation">
         <span class="codicon codicon-link-external"></span>
       </a>
      </div>
      <p class="section-description">Complexity-based stage routing settings</p>
    </div>
  
        
    <div class="section-content">
      <div class="subsection">
        <h4 class="subsection-title">Model Routing</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="model_routing.mode" class="setting-label">Routing Mode </label>
        <p class="setting-description">Manual: use per-stage config only. Automatic: AutoModelSelector determines model for every stage. Hybrid: AutoModelSelector runs but per-stage config overrides take precedence.</p>
        
      </div>
      <div class="setting-control">
        <select id="model_routing.mode"
                class="select-input"
                data-path="model_routing.mode"
                disabled>
          <option value="manual" >Manual</option><option value="automatic" selected>Automatic</option><option value="hybrid" >Hybrid</option>
        </select>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="model_routing.default_effort" class="setting-label">Default Effort </label>
        <p class="setting-description">Default Claude effort level applied to all stages for the active model (sonnet). Overridden by per-stage stage_efforts entries. Silently ignored for models that do not support --effort.</p>
        
      </div>
      <div class="setting-control">
        <select id="model_routing.default_effort"
                class="select-input"
                data-path="model_routing.default_effort"
                disabled>
          <option value="" selected>None (use stage defaults)</option><option value="low" >Low</option><option value="medium" >Medium</option><option value="high" >High</option>
        </select>
      </div>
    </div>
  
      </div>
      <div class="subsection">
        <h4 class="subsection-title">Complexity Thresholds</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="model_routing.complexity_thresholds.haiku_max" class="setting-label">Haiku Max Complexity </label>
        <p class="setting-description">Maximum complexity score for Haiku model. Issues at or below this score use Haiku.</p>
        
      </div>
      <div class="setting-control">
        <input type="number"
               id="model_routing.complexity_thresholds.haiku_max"
               class="number-input"
               data-path="model_routing.complexity_thresholds.haiku_max"
               value="3"
               min="0"
               max="10"
               
               disabled>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="model_routing.complexity_thresholds.sonnet_max" class="setting-label">Sonnet Max Complexity </label>
        <p class="setting-description">Maximum complexity score for Sonnet model. Issues above haiku_max but at or below this score use Sonnet. Above this uses Opus.</p>
        
      </div>
      <div class="setting-control">
        <input type="number"
               id="model_routing.complexity_thresholds.sonnet_max"
               class="number-input"
               data-path="model_routing.complexity_thresholds.sonnet_max"
               value="6"
               min="0"
               max="10"
               
               disabled>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="model_routing.confidence_threshold" class="setting-label">Confidence Threshold </label>
        <p class="setting-description">Minimum confidence for automatic model selection (0.0-1.0). Below this threshold, the selected model is upgraded one tier.</p>
        
      </div>
      <div class="setting-control">
        <input type="number"
               id="model_routing.confidence_threshold"
               class="number-input"
               data-path="model_routing.confidence_threshold"
               value="0.7"
               min="0"
               max="1"
               step="0.05"
               disabled>
      </div>
    </div>
  
      </div>
      <div class="subsection">
        <h4 class="subsection-title">Advanced</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="model_routing.auto_tune" class="setting-label">Auto-Tune Thresholds </label>
        <p class="setting-description">Automatically adjust complexity thresholds based on execution history analysis</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="model_routing.auto_tune"
               class="toggle-input"
               data-path="model_routing.auto_tune"
               
               disabled>
        <label for="model_routing.auto_tune" class="toggle-switch"></label>
      </div>
    </div>
  
      </div>
    </div>
  
      </div>
    
      <div class="section " id="section-enforcement">
        
    <div class="section-header" data-section="enforcement">
      <div class="section-title-row">
        <span class="section-chevron codicon codicon-chevron-down"></span>
        <span class="codicon codicon-lock section-icon"></span>
        <h3 class="section-title">Enforcement</h3>
        
        <a href="#" class="doc-link" data-doc="docs/CONFIGURATION.md#enforcement" title="View documentation">
         <span class="codicon codicon-link-external"></span>
       </a>
      </div>
      <p class="section-description">Dependency enforcement and quality gates</p>
    </div>
  
        
    <div class="section-content">
      <div class="subsection">
        <h4 class="subsection-title">Dependencies</h4>
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="enforcement.dependencies.enabled" class="setting-label">Enable Dependency Checking </label>
        <p class="setting-description">Check issue dependencies before allowing issue-pickup to proceed</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="enforcement.dependencies.enabled"
               class="toggle-input"
               data-path="enforcement.dependencies.enabled"
               checked
               disabled>
        <label for="enforcement.dependencies.enabled" class="toggle-switch"></label>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="enforcement.dependencies.mode" class="setting-label">Enforcement Mode </label>
        <p class="setting-description">How dependency violations are handled: warn logs a warning but allows proceed, block prevents pickup, ignore skips the check</p>
        
      </div>
      <div class="setting-control">
        <select id="enforcement.dependencies.mode"
                class="select-input"
                data-path="enforcement.dependencies.mode"
                disabled>
          <option value="warn" selected>Warn</option><option value="block" >Block</option><option value="ignore" >Ignore</option>
        </select>
      </div>
    </div>
  
        
    <div class="setting-row ">
      <div class="setting-info">
        <label for="enforcement.dependencies.check_transitive" class="setting-label">Check Transitive Dependencies </label>
        <p class="setting-description">Also check indirect dependencies (A depends on B, B depends on C)</p>
        
      </div>
      <div class="setting-control">
        <input type="checkbox"
               id="enforcement.dependencies.check_transitive"
               class="toggle-input"
               data-path="enforcement.dependencies.check_transitive"
               
               disabled>
        <label for="enforcement.dependencies.check_transitive" class="toggle-switch"></label>
      </div>
    </div>
  
      </div>
    </div>
  
      </div>
    
      <div class="section " id="section-commands">
        
    <div class="section-header" data-section="commands">
      <div class="section-title-row">
