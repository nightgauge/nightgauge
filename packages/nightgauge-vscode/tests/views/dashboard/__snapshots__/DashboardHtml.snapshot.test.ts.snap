    <div class="tab-panel" id="tab-panel-runs" role="tabpanel" aria-labelledby="tab-runs">
      <!-- Pipeline Runs History (Issue #3319) — paginated run list with drill-down -->
      
    <div class="runs-loading">
      <div class="empty-icon">⏳</div>
      <p>Loading pipeline runs…</p>
    </div>
  
    </div>

    <div class="tab-panel" id="tab-panel-trends" role="tabpanel" aria-labelledby="tab-trends">
      <!-- Longitudinal Trends (Issue #3320) — success rate, cost, runs over time -->
      
    <div class="trends-empty">
      <div class="trends-empty-icon">⏳</div>
      <p class="trends-empty-title">Loading trends…</p>
    </div>
  
