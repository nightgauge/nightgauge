          <h3>Tool Calls</h3>
          <select class="tool-filter" id="toolFilter">
            <option value="all">All</option>
          </select>
        </div>
        <div class="empty-state">
          <p>No tool calls recorded yet. Tool calls are tracked during pipeline execution.</p>
