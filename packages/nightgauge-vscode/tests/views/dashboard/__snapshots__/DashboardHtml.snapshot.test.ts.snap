    <div class="tab-panel" id="tab-panel-health" role="tabpanel" aria-labelledby="tab-health">
      <!-- Platform Analytics Health (Issue #3318) — 7-dimension health score -->
      
      <div class="health-tab">
        <div class="health-empty-state">
          <div class="health-empty-icon">🏥</div>
          <p class="health-empty-title">Health data unavailable — connect to Nightgauge platform</p>
          <p class="health-empty-hint">Platform health analysis provides 7-dimension pipeline scoring with findings and recommendations.</p>
          <button class="action-btn" id="healthRefreshBtn">Refresh</button>
