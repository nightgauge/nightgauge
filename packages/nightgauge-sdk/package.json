{
  "name": "@nightgauge/sdk",
  "version": "0.1.0",
  "description": "Nightgauge SDK - Programmatic pipeline orchestration using Claude Agent SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nightgauge-sdk": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "LICENSE",
    "NOTICE",
    "THIRD_PARTY_NOTICES"
  ],
  "scripts": {
    "build": "tsc && cp src/analysis/failure-taxonomy.yaml dist/analysis/ && cp src/eval/model-registry.json dist/eval/",
    "prepack": "node ../../scripts/generate-third-party-notices.mjs",
    "postinstall": "node scripts/postinstall.js",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:integration": "vitest run src/__tests__/integration/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "nightgauge",
    "sdlc",
    "pipeline",
    "claude",
    "agent-sdk",
    "automation"
  ],
  "author": {
    "name": "nightgauge"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nightgauge/nightgauge"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@types/handlebars": "^4.1.0",
    "cac": "^7.0.0",
    "handlebars": "^4.7.9",
    "js-yaml": "^5.2.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@google/genai": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.2"
  }
}
