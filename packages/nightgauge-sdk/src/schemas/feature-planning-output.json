{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FeaturePlanningOutput",
  "description": "Output from the feature-planning pipeline stage",
  "type": "object",
  "properties": {
    "plan_summary": {
      "type": "string",
      "description": "One-paragraph plan summary"
    },
    "plan_sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["title", "description"]
      },
      "description": "Plan sections with file references"
    },
    "files_to_create": {
      "type": "array",
      "items": { "type": "string" },
      "description": "New files to create"
    },
    "files_to_modify": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Existing files to modify"
    },
    "files_to_delete": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Files to remove"
    },
    "estimated_complexity": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Overall complexity"
    },
    "test_strategy": { "type": "string", "description": "Testing approach" },
    "risks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Identified risks"
    }
  },
  "required": [
    "plan_summary",
    "plan_sections",
    "files_to_modify",
    "estimated_complexity",
    "test_strategy"
  ]
}
