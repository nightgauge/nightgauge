{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FeatureValidateOutput",
  "description": "Output from the feature-validate pipeline stage",
  "type": "object",
  "properties": {
    "passed": { "type": "boolean", "description": "Overall validation result" },
    "test_results": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" }
      },
      "required": ["total", "passed", "failed"]
    },
    "coverage_delta": {
      "type": "string",
      "description": "Coverage change e.g. '+2.3%'"
    },
    "validation_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "warn", "skip"]
          },
          "detail": { "type": "string" }
        },
        "required": ["name", "status"]
      }
    },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Issues preventing merge"
    }
  },
  "required": ["passed", "test_results", "validation_checks"]
}
