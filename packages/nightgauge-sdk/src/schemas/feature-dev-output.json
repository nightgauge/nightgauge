{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FeatureDevOutput",
  "description": "Output from the feature-dev pipeline stage",
  "type": "object",
  "properties": {
    "files_created": { "type": "array", "items": { "type": "string" } },
    "files_modified": { "type": "array", "items": { "type": "string" } },
    "files_deleted": { "type": "array", "items": { "type": "string" } },
    "tests_added": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Test files created or modified"
    },
    "build_status": { "type": "string", "enum": ["pass", "fail", "skipped"] },
    "lint_status": { "type": "string", "enum": ["pass", "fail", "skipped"] },
    "test_status": { "type": "string", "enum": ["pass", "fail", "skipped"] },
    "commit_sha": { "type": "string", "description": "Last commit SHA" },
    "summary": { "type": "string", "description": "Implementation summary" }
  },
  "required": ["files_modified", "build_status", "lint_status", "test_status", "summary"]
}
